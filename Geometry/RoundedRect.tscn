[sub_resource type="Shader" id="Shader_rounded_rect_9slice"]
code = "shader_type canvas_item;

instance uniform vec4 fill_color : source_color = vec4(0.22, 0.62, 1.0, 1.0);
instance uniform vec4 outline_color : source_color = vec4(1.0, 1.0, 1.0, 1.0);
instance uniform vec2 rect_size = vec2(160.0, 96.0);
instance uniform float corner_radius = 18.0;
instance uniform float outline_width : hint_range(0.0, 1024.0, 0.1) = 4.0;
instance uniform float outline_soft : hint_range(0.0, 64.0, 0.1) = 1.0;

vec2 remap_nine_slice(vec2 target_position, vec2 target_size, float corner_size) {
	float safe_corner = max(corner_size, 0.0);
	vec2 source_size = vec2(safe_corner * 2.0 + 1.0);
	vec2 center_target_size = max(target_size - vec2(safe_corner * 2.0), vec2(1.0));
	vec2 center_source_size = vec2(1.0);
	vec2 remapped_position = target_position;

	if (target_position.x > safe_corner && target_position.x < target_size.x - safe_corner) {
		float center_u = (target_position.x - safe_corner) / center_target_size.x;
		remapped_position.x = safe_corner + center_u * center_source_size.x;
	} else if (target_position.x >= target_size.x - safe_corner) {
		remapped_position.x = source_size.x - (target_size.x - target_position.x);
	}

	if (target_position.y > safe_corner && target_position.y < target_size.y - safe_corner) {
		float center_v = (target_position.y - safe_corner) / center_target_size.y;
		remapped_position.y = safe_corner + center_v * center_source_size.y;
	} else if (target_position.y >= target_size.y - safe_corner) {
		remapped_position.y = source_size.y - (target_size.y - target_position.y);
	}

	return remapped_position;
}

float sd_rounded_box(vec2 position, vec2 half_size, float radius) {
	vec2 distance_to_edge = abs(position) - (half_size - vec2(radius));
	return length(max(distance_to_edge, vec2(0.0))) + min(max(distance_to_edge.x, distance_to_edge.y), 0.0) - radius;
}

void fragment() {
	vec2 safe_rect_size = max(rect_size, vec2(1.0));
	float safe_radius = clamp(corner_radius, 0.0, min(safe_rect_size.x, safe_rect_size.y) * 0.5);
	vec2 target_position = UV * safe_rect_size;
	vec2 remapped_position = remap_nine_slice(target_position, safe_rect_size, safe_radius);
	vec2 virtual_size = vec2(safe_radius * 2.0 + 1.0);
	vec2 centered_position = remapped_position - virtual_size * 0.5;
	float signed_distance = sd_rounded_box(centered_position, virtual_size * 0.5, safe_radius);
	float anti_alias = max(fwidth(signed_distance), 0.0005);
	float outer_fade_width = max(outline_soft, anti_alias);
	float alpha = 1.0 - smoothstep(-outer_fade_width, 0.0, signed_distance);
	float safe_outline_width = max(outline_width, 0.0);
	float fill_boundary = -safe_outline_width;
	float fill_mix = smoothstep(fill_boundary - outer_fade_width, fill_boundary + outer_fade_width, signed_distance);
	vec4 mixed_color = mix(fill_color, outline_color, fill_mix);
	COLOR = vec4(mixed_color.rgb, mixed_color.a * alpha);
}
"

