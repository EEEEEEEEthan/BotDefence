[sub_resource type="GDScript" id="GDScript_rounded_rect_9slice"]
script/source = "@tool
extends Sprite2D

@export var rect_size: Vector2 = Vector2(160.0, 96.0):
	set(value):
		rect_size = value
		_apply_rect_size()

@export_range(0.0, 1024.0, 0.1) var corner_radius: float = 18.0:
	set(value):
		corner_radius = value
		_apply_corner_radius()

@export var fill_color: Color = Color(0.22, 0.62, 1.0, 1.0):
	set(value):
		fill_color = value
		_apply_fill_color()

@export var outline_color: Color = Color(1.0, 1.0, 1.0, 1.0):
	set(value):
		outline_color = value
		_apply_outline_color()

@export_range(0.0, 1024.0, 0.1) var outline_width: float = 4.0:
	set(value):
		outline_width = value
		_apply_outline_width()

@export_range(0.0, 64.0, 0.1) var outline_soft: float = 1.0:
	set(value):
		outline_soft = value
		_apply_outline_soft()

var _is_syncing_transform: bool = false

func _ready() -> void:
	set_notify_transform(true)
	_apply_rect_size()
	_apply_corner_radius()
	_apply_fill_color()
	_apply_outline_color()
	_apply_outline_width()
	_apply_outline_soft()

func _notification(what: int) -> void:
	if what != NOTIFICATION_TRANSFORM_CHANGED:
		return
	if _is_syncing_transform:
		return
	var scaled_size: Vector2 = Vector2(maxf(absf(scale.x), 1.0), maxf(absf(scale.y), 1.0))
	if rect_size.is_equal_approx(scaled_size):
		return
	rect_size = scaled_size
	_apply_rect_size()

func _apply_rect_size() -> void:
	_is_syncing_transform = true
	scale = rect_size
	_is_syncing_transform = false
	set_instance_shader_parameter(&\"rect_size\", rect_size)
	var radius_limit: float = minf(rect_size.x, rect_size.y) * 0.5
	if corner_radius > radius_limit:
		corner_radius = radius_limit
		_apply_corner_radius()

func _apply_corner_radius() -> void:
	var radius_limit: float = minf(rect_size.x, rect_size.y) * 0.5
	var clamped_radius: float = clampf(corner_radius, 0.0, radius_limit)
	if !is_equal_approx(corner_radius, clamped_radius):
		corner_radius = clamped_radius
	set_instance_shader_parameter(&\"corner_radius\", corner_radius)

func _apply_fill_color() -> void:
	set_instance_shader_parameter(&\"fill_color\", fill_color)

func _apply_outline_color() -> void:
	set_instance_shader_parameter(&\"outline_color\", outline_color)

func _apply_outline_width() -> void:
	set_instance_shader_parameter(&\"outline_width\", outline_width)

func _apply_outline_soft() -> void:
	set_instance_shader_parameter(&\"outline_soft\", outline_soft)
"

