[sub_resource type="GDScript" id="GDScript_rounded_triangle"]
script/source = "@tool
extends Sprite2D

var _rect_size: Vector2 = Vector2(160.0, 96.0)
var _base_length: float = 120.0
var _apex_offset_x: float = 0.0
var _corner_radius: float = 8.0
var _fill_color: Color = Color(0.22, 0.62, 1.0, 1.0)
var _outline_color: Color = Color(1.0, 1.0, 1.0, 1.0)
var _outline_width: float = 4.0
var _outline_soft: float = 1.0

@export var rect_size: Vector2 = Vector2(160.0, 96.0):
	get:
		return _rect_size
	set(value):
		_rect_size = value
		if is_node_ready():
			_apply_rect_size()

@export_range(1.0, 4096.0, 0.1) var base_length: float = 120.0:
	get:
		return _base_length
	set(value):
		_base_length = value
		if is_node_ready():
			_apply_base_length()

@export_range(-4096.0, 4096.0, 0.1) var apex_offset_x: float = 0.0:
	get:
		return _apex_offset_x
	set(value):
		_apex_offset_x = value
		if is_node_ready():
			_apply_apex_offset_x()

@export_range(0.0, 1024.0, 0.1) var corner_radius: float = 8.0:
	get:
		return _corner_radius
	set(value):
		_corner_radius = value
		if is_node_ready():
			_apply_corner_radius()

@export var fill_color: Color = Color(0.22, 0.62, 1.0, 1.0):
	get:
		return _fill_color
	set(value):
		_fill_color = value
		if is_node_ready():
			_apply_fill_color()

@export var outline_color: Color = Color(1.0, 1.0, 1.0, 1.0):
	get:
		return _outline_color
	set(value):
		_outline_color = value
		if is_node_ready():
			_apply_outline_color()

@export_range(0.0, 1024.0, 0.1) var outline_width: float = 4.0:
	get:
		return _outline_width
	set(value):
		_outline_width = value
		if is_node_ready():
			_apply_outline_width()

@export_range(0.0, 64.0, 0.1) var outline_soft: float = 1.0:
	get:
		return _outline_soft
	set(value):
		_outline_soft = value
		if is_node_ready():
			_apply_outline_soft()

var _is_syncing_transform: bool = false

func _ready() -> void:
	set_notify_transform(true)
	_apply_rect_size()
	_apply_base_length()
	_apply_apex_offset_x()
	_apply_corner_radius()
	_apply_fill_color()
	_apply_outline_color()
	_apply_outline_width()
	_apply_outline_soft()

func _notification(what: int) -> void:
	if what != NOTIFICATION_TRANSFORM_CHANGED:
		return
	if _is_syncing_transform:
		return
	var scaled_size: Vector2 = Vector2(maxf(absf(scale.x), 1.0), maxf(absf(scale.y), 1.0))
	if _rect_size.is_equal_approx(scaled_size):
		return
	_rect_size = scaled_size
	_apply_rect_size()

func _apply_rect_size() -> void:
	_rect_size = Vector2(maxf(_rect_size.x, 1.0), maxf(_rect_size.y, 1.0))
	_is_syncing_transform = true
	scale = _rect_size
	_is_syncing_transform = false
	set_instance_shader_parameter(&\"rect_size\", _rect_size)
	_apply_base_length()
	_apply_apex_offset_x()
	_apply_corner_radius()

func _apply_base_length() -> void:
	var max_base_length: float = maxf(_rect_size.x - _corner_radius * 2.0, 1.0)
	var clamped_base_length: float = clampf(_base_length, 1.0, max_base_length)
	if !is_equal_approx(_base_length, clamped_base_length):
		_base_length = clamped_base_length
	set_instance_shader_parameter(&\"base_length\", _base_length)

func _apply_apex_offset_x() -> void:
	var half_base_length: float = _base_length * 0.5
	var clamped_apex_offset: float = clampf(_apex_offset_x, -half_base_length, half_base_length)
	if !is_equal_approx(_apex_offset_x, clamped_apex_offset):
		_apex_offset_x = clamped_apex_offset
	set_instance_shader_parameter(&\"apex_offset_x\", _apex_offset_x)

func _apply_corner_radius() -> void:
	var max_corner_radius: float = minf(_base_length, _rect_size.y) * 0.5
	var clamped_corner_radius: float = clampf(_corner_radius, 0.0, max_corner_radius)
	if !is_equal_approx(_corner_radius, clamped_corner_radius):
		_corner_radius = clamped_corner_radius
	_apply_base_length()
	_apply_apex_offset_x()
	set_instance_shader_parameter(&\"corner_radius\", _corner_radius)

func _apply_fill_color() -> void:
	set_instance_shader_parameter(&\"fill_color\", _fill_color)

func _apply_outline_color() -> void:
	set_instance_shader_parameter(&\"outline_color\", _outline_color)

func _apply_outline_width() -> void:
	set_instance_shader_parameter(&\"outline_width\", _outline_width)

func _apply_outline_soft() -> void:
	set_instance_shader_parameter(&\"outline_soft\", _outline_soft)
"

