[sub_resource type="Shader" id="Shader_rounded_triangle"]
code = "shader_type canvas_item;

instance uniform vec4 fill_color : source_color = vec4(0.22, 0.62, 1.0, 1.0);
instance uniform vec4 outline_color : source_color = vec4(1.0, 1.0, 1.0, 1.0);
instance uniform vec2 rect_size = vec2(160.0, 96.0);
instance uniform float base_length = 120.0;
instance uniform float apex_offset_x = 0.0;
instance uniform float corner_radius = 8.0;
instance uniform float outline_width : hint_range(0.0, 1024.0, 0.1) = 4.0;
instance uniform float outline_soft : hint_range(0.0, 64.0, 0.1) = 1.0;

float sd_triangle(vec2 point, vec2 vertex_a, vec2 vertex_b, vec2 vertex_c) {
	vec2 edge_ab = vertex_b - vertex_a;
	vec2 edge_bc = vertex_c - vertex_b;
	vec2 edge_ca = vertex_a - vertex_c;

	vec2 point_to_a = point - vertex_a;
	vec2 point_to_b = point - vertex_b;
	vec2 point_to_c = point - vertex_c;

	vec2 projection_ab = point_to_a - edge_ab * clamp(dot(point_to_a, edge_ab) / dot(edge_ab, edge_ab), 0.0, 1.0);
	vec2 projection_bc = point_to_b - edge_bc * clamp(dot(point_to_b, edge_bc) / dot(edge_bc, edge_bc), 0.0, 1.0);
	vec2 projection_ca = point_to_c - edge_ca * clamp(dot(point_to_c, edge_ca) / dot(edge_ca, edge_ca), 0.0, 1.0);

	float orientation = sign(edge_ab.x * edge_ca.y - edge_ab.y * edge_ca.x);

	vec2 distance_and_side = min(
		min(
			vec2(dot(projection_ab, projection_ab), orientation * (point_to_a.x * edge_ab.y - point_to_a.y * edge_ab.x)),
			vec2(dot(projection_bc, projection_bc), orientation * (point_to_b.x * edge_bc.y - point_to_b.y * edge_bc.x))
		),
		vec2(dot(projection_ca, projection_ca), orientation * (point_to_c.x * edge_ca.y - point_to_c.y * edge_ca.x))
	);

	return -sqrt(distance_and_side.x) * sign(distance_and_side.y);
}

void fragment() {
	vec2 safe_rect_size = max(rect_size, vec2(1.0));
	float safe_corner_radius = max(corner_radius, 0.0);
	float max_base_length = max(safe_rect_size.x - safe_corner_radius * 2.0, 1.0);
	float safe_base_length = clamp(base_length, 1.0, max_base_length);
	vec2 point = UV * safe_rect_size;

	vec2 triangle_center = vec2(safe_rect_size.x * 0.5, safe_rect_size.y);
	vec2 vertex_left = triangle_center + vec2(-safe_base_length * 0.5, -safe_corner_radius);
	vec2 vertex_right = triangle_center + vec2(safe_base_length * 0.5, -safe_corner_radius);
	vec2 vertex_apex = vec2(triangle_center.x + apex_offset_x, safe_corner_radius);

	float signed_distance = sd_triangle(point, vertex_left, vertex_right, vertex_apex) - safe_corner_radius;
	float anti_alias = max(fwidth(signed_distance), 0.0005);
	float outer_fade_width = max(outline_soft, anti_alias);
	float alpha = 1.0 - smoothstep(-outer_fade_width, 0.0, signed_distance);

	float safe_outline_width = max(outline_width, 0.0);
	float fill_boundary = -safe_outline_width;
	float fill_mix = smoothstep(fill_boundary - outer_fade_width, fill_boundary + outer_fade_width, signed_distance);
	vec4 mixed_color = mix(fill_color, outline_color, fill_mix);
	COLOR = vec4(mixed_color.rgb, mixed_color.a * alpha);
}
"

