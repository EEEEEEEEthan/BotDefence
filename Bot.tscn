script/source = "extends Node2D

## 主线程 Bot 逻辑，通过 call_deferred 接收 Bot 的 move_forward/turn 请求
## 移动与转向由 MoveForwardState、TurnState 子节点封装
## 移动/转向瞬时修改 preferred_position/preferred_rotation，等待后 callback，BotMain 每帧插值

const DEFAULT_CODE_PATH := \"res://player_code.gd\"

## 运行时错误 Logger：将玩家脚本抛出的错误转发到 printed，供 Inspector Console 显示
## start_bot 会先 abort() 等待前一线程，故同一时刻仅一个 Bot 在跑，用 _active_bot 即可
class RuntimeErrorLogger extends Logger:
	static var _active_bot: WeakRef
	static var _mutex: Mutex = Mutex.new()
	static var _instance: RuntimeErrorLogger
	static var _registered: bool = false

	static func ensure_registered() -> void:
		if _registered:
			return
		_instance = RuntimeErrorLogger.new()
		OS.add_logger(_instance)
		_registered = true

	static func set_active_bot(bot_ref: WeakRef) -> void:
		_mutex.lock()
		_active_bot = bot_ref
		_mutex.unlock()

	static func clear_active_bot() -> void:
		_mutex.lock()
		_active_bot = null
		_mutex.unlock()

	func _log_error(_function: String, _file: String, error_line: int, code: String, rationale: String, _editor_notify: bool, _error_type: int, script_backtraces: Array) -> void:
		_mutex.lock()
		var bot_ref: WeakRef = _active_bot
		_mutex.unlock()
		if not bot_ref:
			return
		var bot: Object = bot_ref.get_ref()
		if not bot or not bot.has_method(\"_print_runtime_error\"):
			return
		bot.call_deferred(\"_print_runtime_error\", rationale if rationale else code, error_line, script_backtraces)
		RuntimeErrorLogger.clear_active_bot()

signal current_line_changed(line: int)  ## -1 表示无执行行
signal printed(entry: ConsoleLogEntry)  ## BotApi.print/print_error 转发，供 Inspector Console 显示

@onready var _bot_api: Node = $%BotApi
var cardinal: Consts.Cardinal = Consts.Cardinal.NORTH

var preferred_position: Vector2:
	get: return _preferred_position
	set(value): _preferred_position = value
var _preferred_position: Vector2

var preferred_rotation: float:
	get: return _preferred_rotation
	set(value): _preferred_rotation = value
var _preferred_rotation: float

const _POSITION_LERP_SPEED := 8.0
const _ROTATION_LERP_SPEED := 12.0
const _CARDINAL_ANGLE := {
	Consts.Cardinal.NORTH: 0.0,
	Consts.Cardinal.EAST: TAU / 4,
	Consts.Cardinal.SOUTH: TAU / 2,
	Consts.Cardinal.WEST: -TAU / 4
}
var _current_state: Object  ## MoveForwardState 或 TurnState，均有 abort()
var _player_thread: Thread
var _running := false
var _current_execution_line: int = -1

var current_execution_line: int:
	get: return _current_execution_line

var running: bool:
	get: return _running

@export_multiline
var code: String

var _print_buffer: Array[ConsoleLogEntry] = []  ## 记录所有 print，供中途打开的 Inspector 显示
var _injected_to_original: Dictionary = {}  ## 注入后行号(1-based) -> 原始行号(1-based)，供运行时错误映射
var _error_occurred: bool = false  ## 报错后置 true，阻止后续 deferred print

func _ready() -> void:
	_preferred_position = position
	_preferred_rotation = _CARDINAL_ANGLE[cardinal]
	rotation = _preferred_rotation

func _process(delta: float) -> void:
	position = position.lerp(_preferred_position, 1.0 - exp(-_POSITION_LERP_SPEED * delta))
	rotation = lerp_angle(rotation, _preferred_rotation, 1.0 - exp(-_ROTATION_LERP_SPEED * delta))

func start_bot() -> void:
	abort()
	_print_buffer.clear()
	_injected_to_original.clear()
	_error_occurred = false
	_running = true
	RuntimeErrorLogger.ensure_registered()
	var gdscript := GDScript.new()
	gdscript.source_code = _inject_line_tracking(code)
	gdscript.reload()
	var instance: Object = gdscript.new()
	var bot_api: Node = _bot_api
	var report_line := func(line: int): self.call_deferred(&\"_set_current_line\", line)
	var abort_check := func() -> bool: return not _running
	_player_thread = Thread.new()
	_player_thread.start(_run_bot_script.bind(instance, bot_api, report_line, abort_check))

func _run_bot_script(instance: Object, bot_api: Node, report_line: Callable, abort_check: Callable) -> void:
	RuntimeErrorLogger.set_active_bot(weakref(self))
	instance.run(bot_api, report_line, abort_check)
	call_deferred(&\"_on_thread_finished\")

func _on_thread_finished() -> void:
	RuntimeErrorLogger.clear_active_bot()
	_clear_execution_line()

func _set_current_line(line: int) -> void:
	if _current_execution_line == line:
		return
	_current_execution_line = line
	current_line_changed.emit(line)

func _clear_execution_line() -> void:
	_running = false
	_set_current_line(-1)

func _print_message(text: String, entry_type: ConsoleLogEntry.Type) -> void:
	if _error_occurred and entry_type == ConsoleLogEntry.Type.LOG:
		return
	var entry: ConsoleLogEntry = ConsoleLogEntry.new(int(Time.get_unix_time_from_system()), entry_type, text)
	_print_buffer.append(entry)
	printed.emit(entry)

func _print_runtime_error(msg: String, injected_line: int, script_backtraces: Array = []) -> void:
	_error_occurred = true
	## 引擎有时报告下一行，优先用 injected_line-1 的映射
	var original_line: int = _injected_to_original.get(injected_line - 1, -1)
	if original_line < 0:
		original_line = _injected_to_original.get(injected_line, -1)
	if original_line < 0:
		var best_key: int = 0
		for key in _injected_to_original:
			if key <= injected_line and key > best_key:
				best_key = key
		original_line = _injected_to_original[best_key] if best_key > 0 else injected_line
	if original_line > 0:
		msg = \"第%d行: %s\" % [original_line, msg]
	var stack_str: String = _format_user_stack_only(script_backtraces)
	if stack_str:
		msg += \"\\n\" + stack_str
	_print_message(msg, ConsoleLogEntry.Type.ERROR)
	_clear_execution_line()
	RuntimeErrorLogger.clear_active_bot()

## 只保留 gdscript:// 动态脚本的调用帧，过滤掉 res:// 等引擎/项目脚本，行号映射到原始源码
func _format_user_stack_only(script_backtraces: Array) -> String:
	var max_original: int = 0
	for val in _injected_to_original.values():
		if val > max_original:
			max_original = val
	var lines: PackedStringArray = []
	for bt in script_backtraces:
		if bt.has_method(\"is_empty\") and bt.is_empty():
			continue
		if not bt.has_method(\"get_frame_count\") or not bt.has_method(\"get_frame_file\"):
			continue
		var frame_count: int = bt.get_frame_count()
		var prev_func_name: String = \"\"
		for frame_idx in frame_count:
			var file_path: String = bt.get_frame_file(frame_idx)
			if not file_path.begins_with(\"gdscript://\"):
				continue
			var func_name: String = bt.get_frame_function(frame_idx) if bt.has_method(\"get_frame_function\") else \"?\"
			var frame_line: int = bt.get_frame_line(frame_idx) if bt.has_method(\"get_frame_line\") else 0
			var original_line: int = -1
			if frame_idx == 0:
				## 顶层帧（错误发生处）：用映射
				for offset in [0, -1, 1]:
					var key: int = frame_line + offset
					if key > 0:
						original_line = _injected_to_original.get(key, -1)
						if original_line > 0:
							break
				if original_line <= 0:
					var best_key: int = 0
					for key in _injected_to_original:
						if key <= frame_line and key > best_key:
							best_key = key
					original_line = _injected_to_original[best_key] if best_key > 0 else frame_line
			else:
				## 调用者帧：引擎常返回错误行，需从源码推断调用行
				original_line = _find_call_line(func_name, prev_func_name)
				if original_line <= 0 and frame_line >= 1 and frame_line <= max_original:
					original_line = frame_line
				if original_line <= 0:
					for offset in [0, -1, 1]:
						var key: int = frame_line + offset
						if key > 0:
							original_line = _injected_to_original.get(key, -1)
							if original_line > 0:
								break
				if original_line <= 0:
					original_line = frame_line
			prev_func_name = func_name
			if original_line <= 0:
				original_line = frame_line
			lines.append(\"  %s (第%d行)\" % [func_name, original_line])
	if lines.is_empty():
		return \"\"
	return \"GDScript backtrace (most recent call first):\\n\" + \"\\n\".join(lines)

## 在 caller_func 体内查找调用 callee_func 的行号（1-based）
func _find_call_line(caller_func: String, callee_func: String) -> int:
	if callee_func.is_empty():
		return -1
	var source_lines: PackedStringArray = code.split(\"\\n\")
	var in_caller: bool = false
	var caller_indent: int = -1
	for line_index in source_lines.size():
		var line: String = source_lines[line_index]
		var stripped: String = line.strip_edges()
		if stripped.begins_with(\"func \") and stripped.contains(caller_func + \"(\"):
			in_caller = true
			caller_indent = line.length() - line.lstrip(\" \\t\").length()
			continue
		if in_caller:
			var indent: int = line.length() - line.lstrip(\" \\t\").length()
			if indent <= caller_indent and stripped.begins_with(\"func \"):
				break
			if indent > caller_indent and (callee_func + \"(\") in stripped:
				return line_index + 1
	return -1

func get_print_history() -> Array[ConsoleLogEntry]:
	return _print_buffer.duplicate()

## 在所有顶层函数体内每行前注入行号报告与 abort 检查
## run() 接收 __report_line、__abort_check，每行执行前检查 abort 以支持协作式退出（含死循环）
## 同时填充 _injected_to_original：注入后行号(1-based) -> 原始行号(1-based)
func _inject_line_tracking(source: String) -> String:
	var lines := source.split(\"\\n\")
	var result: Array[String] = []
	var result_line := 0
	var emit := func(line: String, original: int) -> void:
		result.append(line)
		result_line += 1
		if original >= 0:
			_injected_to_original[result_line] = original + 1
	var ensure_vars := func() -> void:
		emit.call(\"var __report_line_internal: Callable\", -1)
		emit.call(\"var __abort_check_internal: Callable\", -1)
	var in_func_body := false
	var in_run_func := false
	var body_indent := 0
	var vars_added := false
	for line_index in lines.size():
		var line: String = lines[line_index]
		var stripped := line.strip_edges()
		var indent_len := line.length() - line.lstrip(\" \\t\").length()
		if in_func_body:
			if stripped.is_empty():
				emit.call(line, line_index)
				continue
			if indent_len <= body_indent:
				in_func_body = stripped.begins_with(\"func \")
				if in_func_body:
					in_run_func = stripped.begins_with(\"func run\")
					body_indent = indent_len
					if not vars_added:
						ensure_vars.call()
						vars_added = true
					if in_run_func:
						var paren_idx := line.find(\")\")
						if paren_idx >= 0:
							line = line.substr(0, paren_idx) + \", __report_line, __abort_check\" + line.substr(paren_idx)
				emit.call(line, line_index)
				continue
			var indent_str := line.substr(0, indent_len)
			if in_run_func:
				emit.call(indent_str + \"__report_line_internal = __report_line\", line_index)
				emit.call(indent_str + \"__abort_check_internal = __abort_check\", line_index)
				in_run_func = false
			emit.call(indent_str + \"if __abort_check_internal.call(): return\", line_index)
			emit.call(indent_str + \"__report_line_internal.call(\" + str(line_index) + \")\", line_index)
			emit.call(line, line_index)
			continue
		if stripped.begins_with(\"func \"):
			if not vars_added:
				ensure_vars.call()
				vars_added = true
			in_func_body = true
			in_run_func = stripped.begins_with(\"func run\")
			body_indent = indent_len
			if in_run_func:
				var paren_idx := line.find(\")\")
				if paren_idx >= 0:
					line = line.substr(0, paren_idx) + \", __report_line, __abort_check\" + line.substr(paren_idx)
		elif not vars_added and (stripped.begins_with(\"extends \") or stripped.begins_with(\"class_name \")):
			emit.call(line, line_index)
			ensure_vars.call()
			vars_added = true
			continue
		emit.call(line, line_index)
	return \"\\n\".join(result)

## 由 Bot 通过 call_deferred 调用，仅转发给 MoveForwardState
func move_forward(callback: Callable) -> void:
	var wrapped := func(arrived: bool):
		_current_state = null
		callback.call(arrived)
	_current_state = $%MoveForwardState
	_current_state.start(cardinal, wrapped)

const _CARDINAL_ORDER := [Consts.Cardinal.NORTH, Consts.Cardinal.EAST, Consts.Cardinal.SOUTH, Consts.Cardinal.WEST]

func turn_left(callback: Callable) -> void:
	var idx: int = _CARDINAL_ORDER.find(cardinal)
	var new_cardinal: Consts.Cardinal = _CARDINAL_ORDER[(idx + 3) % 4]
	var wrapped := func(arrived: bool):
		_current_state = null
		callback.call(arrived)
	_current_state = $%TurnState
	_current_state.start(new_cardinal, wrapped)

func turn_right(callback: Callable) -> void:
	var idx: int = _CARDINAL_ORDER.find(cardinal)
	var new_cardinal: Consts.Cardinal = _CARDINAL_ORDER[(idx + 1) % 4]
	var wrapped := func(arrived: bool):
		_current_state = null
		callback.call(arrived)
	_current_state = $%TurnState
	_current_state.start(new_cardinal, wrapped)

## 退出时调用，中止当前任务
func abort() -> void:
	_running = false
	if _current_state:
		_current_state.abort()
		_current_state = null
	if _player_thread and _player_thread.is_alive():
		_player_thread.wait_to_finish()
		_player_thread = null

func _exit_tree() -> void:
	abort()

func _unhandled_input(event: InputEvent) -> void:
	if not (event is InputEventMouseButton and event.pressed and event.button_index == MOUSE_BUTTON_LEFT):
		return
	var sprite: Sprite2D = $Sprite2D
	var rect: Rect2 = sprite.get_rect()
	var global_rect := Rect2(
		sprite.global_position + rect.position * sprite.global_scale,
		rect.size * sprite.global_scale
	)
	if global_rect.has_point(get_global_mouse_position()):
		_open_inspector()

func _open_inspector() -> void:
	var placeholder: InstancePlaceholder = $BotInspector
	var inspector: Window = load(placeholder.get_instance_path()).instantiate()
	inspector.bot = self
	get_tree().root.add_child(inspector)
	inspector.popup_centered()
"

[sub_resource type="GDScript" id="GDScript_ro7h1"]
script/source = "extends Node
class_name Bot

## 玩家可见的 Bot API，作为 BotMain 的子节点
## 子线程中通过 call_deferred 将操作交给 BotMain，完成后 callback 解除阻塞
## 返回 true=完成，false=被取消

var cardinal: Consts.Cardinal:
	get: return get_parent().cardinal

func move_forward() -> bool:
	return _deferred_call(\"move_forward\")

func turn_left() -> bool:
	return _deferred_call(\"turn_left\")

func turn_right() -> bool:
	return _deferred_call(\"turn_right\")

func print(what: Variant) -> void:
	get_parent().call_deferred(\"_print_message\", str(what), ConsoleLogEntry.Type.LOG)

func print_error(what: Variant) -> void:
	get_parent().call_deferred(\"_print_message\", str(what), ConsoleLogEntry.Type.ERROR)

func _deferred_call(method: StringName) -> bool:
	var semaphore := Semaphore.new()
	var result := [false]
	var on_done := func(done: bool):
		result[0] = done
		semaphore.post()
	owner.call_deferred(method, on_done)
	semaphore.wait()
	return result[0]
"

[sub_resource type="GDScript" id="GDScript_q6hsy"]
script/source = "extends Node
class_name MoveForwardState

## 沿 direction 移动一格，目标为 platform 则抵达后 callback(true)，否则等待后 callback(false)
## 无论是否 platform 都等待 MOVE_DURATION

const MOVE_DURATION := 1.0

var _callback: Callable
var _timer: Timer
var _moved := false

func _ready() -> void:
	_timer = Timer.new()
	_timer.one_shot = true
	add_child(_timer)
	_timer.timeout.connect(_on_timeout)

func start(direction: Consts.Cardinal, callback: Callable) -> void:
	_callback = callback
	var tilemap: TileMapLayer = owner.owner.tilemap
	var tile_set: TileSet = tilemap.tile_set
	var offset: Vector2 = Consts.CARDINAL_TO_DIRECTION[direction]
	var tile_size: Vector2 = Vector2(tile_set.tile_size) * tilemap.scale
	var tile_x: float = floor(owner.position.x / tile_size.x)
	var tile_y: float = floor(owner.position.y / tile_size.y)
	var target_tile := Vector2i(int(tile_x), int(tile_y)) + Vector2i(int(offset.x), int(offset.y))
	var tile_data: TileData = tilemap.get_cell_tile_data(target_tile)
	var is_platform: bool = tile_data != null and tile_data.get_custom_data(\"platform\") == true
	if is_platform:
		var current_center := Vector2(tile_x * tile_size.x + tile_size.x / 2, tile_y * tile_size.y + tile_size.y / 2)
		owner.preferred_position = current_center + offset * tile_size
		_moved = true
	else:
		_moved = false
	_timer.start(MOVE_DURATION)

func abort() -> void:
	_timer.stop()
	_finish(false)

func _on_timeout() -> void:
	var result: bool = _moved
	_finish(result)

func _finish(result: bool) -> void:
	if _callback.is_valid():
		_callback.call(result)
		_callback = Callable()
"

[sub_resource type="GDScript" id="GDScript_ybhwq"]
script/source = "extends Node
class_name TurnState

## 瞬时设置 cardinal 与 preferred_rotation，等待 TURN_DURATION 后 callback
## 实际旋转由 BotMain 每帧插值

const TURN_DURATION := 0.5
const _CARDINAL_ANGLE := {
	Consts.Cardinal.NORTH: 0.0,
	Consts.Cardinal.EAST: TAU / 4,
	Consts.Cardinal.SOUTH: TAU / 2,
	Consts.Cardinal.WEST: -TAU / 4
}

var _callback: Callable
var _running := false
var _timer: Timer

func _ready() -> void:
	_timer = Timer.new()
	_timer.one_shot = true
	add_child(_timer)
	_timer.timeout.connect(_on_timeout)

func start(new_cardinal: Consts.Cardinal, callback: Callable) -> void:
	_callback = callback
	_running = true
	owner.cardinal = new_cardinal
	owner.preferred_rotation = _CARDINAL_ANGLE[new_cardinal]
	_timer.start(TURN_DURATION)

func abort() -> void:
	_timer.stop()
	_finish(false)

func _on_timeout() -> void:
	_finish(true)

func _finish(result: bool) -> void:
	_running = false
	if _callback.is_valid():
		_callback.call(result)
		_callback = Callable()
"

