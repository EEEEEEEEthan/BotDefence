[gd_scene format=3 uid="uid://0u8vi8jcjmxw"]

[sub_resource type="GDScript" id="GDScript_3mrqo"]
script/source = "extends RigidBody2D

## 游戏开始后沿导航网格移动到目标点，带物理碰撞与群体推挤
## 用 velocity lerp 实现转角平滑，RigidBody2D 间自然推挤

const MOVE_SPEED: float = 200.0
const VELOCITY_SMOOTH: float = 6.0
const GOAL_CENTER: Vector2 = Vector2(565, 679)
## 终点附近每人目标点在圆盘内随机，避免共线追逐同一点排成一队
const GOAL_CROWD_RADIUS: float = 32.0

@onready var nav_agent: NavigationAgent2D = $%NavigationAgent2D

func _ready() -> void:
	lock_rotation = true
	nav_agent.target_position = GOAL_CENTER + _random_goal_disk_offset(GOAL_CROWD_RADIUS)
	await get_tree().process_frame


func _random_goal_disk_offset(max_radius: float) -> Vector2:
	var angle := randf() * TAU
	var radius := sqrt(randf()) * max_radius
	return Vector2.from_angle(angle) * radius


func _physics_process(delta: float) -> void:
	if nav_agent.is_navigation_finished():
		linear_velocity = linear_velocity.lerp(Vector2.ZERO, VELOCITY_SMOOTH * delta)
		return
	var next_position: Vector2 = nav_agent.get_next_path_position()
	var direction: Vector2 = (next_position - global_position).normalized()
	var target_velocity: Vector2 = direction * MOVE_SPEED
	linear_velocity = linear_velocity.lerp(target_velocity, VELOCITY_SMOOTH * delta)
"

